-size: var(--text-xl);\n  font-weight: 700;\n  margin-bottom: var(--space-6);\n  line-height: var(--leading-snug);\n}\n.quiz__options { display: flex; flex-direction: column; gap: var(--space-3); }\n.quiz__option {\n  padding: var(--space-4) var(--space-5);\n  border: 2px solid var(--color-border);\n  border-radius: var(--radius-md);\n  cursor: pointer;\n  font-size: var(--text-base);\n  transition: all var(--duration-fast) var(--ease-out);\n  background: transparent;\n  text-align: left;\n  width: 100%;\n  font-family: var(--font-body);\n}\n.quiz__option:hover { border-color: var(--color-accent); background: var(--color-accent-light); }\n.quiz__option.correct { border-color: var(--color-success); background: var(--color-success-light); }\n.quiz__option.incorrect { border-color: var(--color-error); background: var(--color-error-light); }\n.quiz__option.disabled { pointer-events: none; opacity: 0.6; }\n.quiz__feedback {\n  margin-top: var(--space-4);\n  padding: var(--space-4);\n  border-radius: var(--radius-md);\n  font-size: var(--text-sm);\n  line-height: var(--leading-loose);\n  display: none;\n}\n.quiz__feedback.show { display: block; }\n.quiz__feedback--correct { background: var(--color-success-light); color: var(--color-success); }\n.quiz__feedback--incorrect { background: var(--color-error-light); color: var(--color-error); }\n\n/* TOOLTIP */\n.term {\n  border-bottom: 1.5px dashed var(--color-text-muted);\n  cursor: pointer;\n  position: relative;\n  display: inline;\n}\n.tooltip {\n  position: fixed;\n  background: var(--color-text);\n  color: white;\n  padding: var(--space-3) var(--space-4);\n  border-radius: var(--radius-sm);\n  font-size: var(--text-xs);\n  line-height: var(--leading-loose);\n  max-width: 280px;\n  z-index: 9999;\n  pointer-events: none;\n  box-shadow: var(--shadow-lg);\n  display: none;\n}\n.tooltip.show { display: block; }\n.tooltip::before {\n  content: '';\n  position: absolute;\n  top: -6px;\n  left: 16px;\n  width: 10px;\n  height: 10px;\n  background: var(--color-text);\n  transform: rotate(45deg);\n}\n\n/* ICON ROWS */\n.icon-row {\n  display: flex;\n  gap: var(--space-4);\n  flex-wrap: wrap;\n  margin: var(--space-6) 0;\n}\n.icon-item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: var(--space-2);\n  padding: var(--space-4);\n  background: var(--color-surface);\n  border: 1px solid var(--color-border-light);\n  border-radius: var(--radius-md);\n  min-width: 100px;\n  text-align: center;\n  box-shadow: var(--shadow-sm);\n}\n.icon-item__emoji { font-size: var(--text-2xl); }\n.icon-item__label { font-size: var(--text-xs); color: var(--color-text-secondary); font-weight: 500; }\n\n/* FILE TREE */\n.file-tree {\n  font-family: var(--font-mono);\n  font-size: var(--text-sm);\n  background: var(--color-bg-code);\n  color: #CDD6F4;\n  padding: var(--space-5);\n  border-radius: var(--radius-md);\n  margin: var(--space-6) 0;\n  overflow-x: auto;\n}\n.file-tree__line { display: flex; gap: var(--space-3); line-height: 1.8; }\n.file-tree__indent { color: rgba(255,255,255,0.2); user-select: none; }\n.file-tree__name { color: #89B4FA; }\n.file-tree__dir { color: #F9E2AF; }\n\n/* STREAMING ANIMATION */\n.streaming-demo {\n  background: var(--color-bg-code);\n  border-radius: var(--radius-md);\n  padding: var(--space-5);\n  margin: var(--space-6) 0;\n  font-family: var(--font-mono);\n  font-size: var(--text-sm);\n  color: #CDD6F4;\n}\n.streaming-token {\n  display: inline;\n  opacity: 0;\n  animation: tokenReveal 0.3s ease-out forwards;\n}\n@keyframes tokenReveal {\n  from { opacity: 0; }\n  to { opacity: 1; }\n}\n\n/* RESPONSIVE */\n@media (max-width: 768px) {\n  .module { padding: calc(var(--nav-height) + var(--space-8)) var(--space-5) var(--space-12); }\n  .module__title { font-size: var(--text-3xl); }\n  .grid-2 { grid-template-columns: 1fr; }\n  .translation-block__grid { grid-template-columns: 1fr; }\n  .translation-block__code { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); }\n  .pattern-cards { grid-template-columns: 1fr 1fr; }\n  .chat-bubble { max-width: 90%; }\n}\n@media (max-width: 480px) {\n  .module__title { font-size: var(--text-2xl); }\n  .nav-title { display: none; }\n  .pattern-cards { grid-template-columns: 1fr; }\n}\n</style>\n</head>\n<body>\n\n<nav class=\"nav\">\n  <span class=\"nav-title\">Build the Deep Agents CLI — From Scratch</span>\n  <div class=\"nav-dots\" id=\"navDots\"></div>\n  <div class=\"nav-progress\" id=\"navProgress\"></div>\n</nav>\n\n\n<!-- MODULE 1: Project Setup -->\n<section class=\"module\" id=\"module-1\">\n  <div class=\"module__inner\">\n\n    <div class=\"module__header animate-in\">\n      <div class=\"module__number\">Module 1</div>\n      <h1 class=\"module__title\">Project Setup</h1>\n      <p class=\"module__subtitle\">Create the package scaffold, install dependencies, and build the CLI entry point.</p>\n    </div>\n\n    <!-- Screen 1: What We're Building -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">What we're building</h2>\n      <p class=\"text-lead mb-6\">By module 8, you'll have a fully functional AI CLI with streaming responses, tool calling, HITL approval, conversation history, skills, and slash commands.</p>\n      \n      <div class=\"file-tree\">\n        <div class=\"file-tree__line\"><span class=\"file-tree__indent\">│</span><span class=\"file-tree__dir\">deepagents_cli/</span></div>\n        <div class=\"file-tree__line\"><span class=\"file-tree__indent\">├──</span><span class=\"file-tree__name\">main.py</span> — entry point with subcommands</div>\n        <div class=\"file-tree__line\"><span class=\"file-tree__indent\">├──</span><span class=\"file-tree__name\">agent.py</span> — LangGraph agent builder</div>\n        <div class=\"file-tree__line\"><span class=\"file-tree__indent\">├──</span><span class=\"file-tree__name\">config.py</span> — settings & glyphs</div>\n        <div class=\"file-tree__line\"><span class=\"file-tree__indent\">├──</span><span class=\"file-tree__name\">app.py</span> — Textual TUI</div>\n        <div class=\"file-tree__line\"><span class=\"file-tree__indent\">├──</span><span class=\"file-tree__name\">command_registry.py</span> — slash commands</div>\n        <div class=\"file-tree__line\"><span class=\"file-tree__indent\">└──</span><span class=\"file-tree__dir\">skills/</span> — skills middleware</div>\n      </div>\n\n      <div class=\"icon-row\">\n        <div class=\"icon-item\">\n          <span class=\"icon-item__emoji\">🐍</span>\n          <span class=\"icon-item__label\">Python 3.11+</span>\n        </div>\n        <div class=\"icon-item\">\n          <span class=\"icon-item__emoji\">🎨</span>\n          <span class=\"icon-item__label\">Textual TUI</span>\n        </div>\n        <div class=\"icon-item\">\n          <span class=\"icon-item__emoji\">🔗</span>\n          <span class=\"icon-item__label\">LangChain + LangGraph</span>\n        </div>\n        <div class=\"icon-item\">\n          <span class=\"icon-item__emoji\">🤖</span>\n          <span class=\"icon-item__label\">Anthropic Claude</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 2: Initialize Project -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Initialize the project</h2>\n      <p class=\"text-lead mb-6\">Start by creating the package structure with <span class=\"term\" data-tip=\"uv is a fast Python package resolver and installer, written in Rust. It replaces pip and poetry.\">uv</span>.</p>\n\n      <div class=\"step-cards\">\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">1</div>\n          <div>\n            <div class=\"step-card__title\">Create the package</div>\n            <div class=\"step-card__desc\">Run <code>uv init --package deepagents-cli</code> to scaffold the project.</div>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">2</div>\n          <div>\n            <div class=\"step-card__title\">Define dependencies</div>\n            <div class=\"step-card__desc\">Edit <code>pyproject.toml</code> to declare required packages.</div>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">3</div>\n          <div>\n            <div class=\"step-card__title\">Install packages</div>\n            <div class=\"step-card__desc\">Run <code>uv sync</code> to install all dependencies.</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"callout callout--info\">\n        <span class=\"callout__icon\">💡</span>\n        <div class=\"callout__content\">\n          <div class=\"callout__title\">Why uv?</div>\n          uv is 10-100x faster than pip and handles dependency resolution intelligently. It also manages virtual environments automatically.\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 3: Install Dependencies -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Install dependencies</h2>\n      <p class=\"text-lead mb-6\">Add these packages to your <code>pyproject.toml</code>.</p>\n\n      <div class=\"translation-block\">\n        <div class=\"translation-block__header\">pyproject.toml dependencies</div>\n        <div class=\"translation-block__grid\">\n          <div class=\"translation-block__code\">\n<div class=\"code-pre\" style=\"white-space: pre-wrap; word-break: break-word;\"><span class=\"code-line\"><span class=\"code-line__num\">1</span><span>[project]</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">2</span><span>name = \"deepagents-cli\"</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">3</span><span>dependencies = [</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">4</span><span>  \"textual>=0.50\",</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">5</span><span>  \"langchain-anthropic>=0.1\",</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">6</span><span>  \"langgraph>=0.0.55\",</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">7</span><span>  \"anthropic>=0.20\",</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">8</span><span>  \"python-dotenv>=1.0\",</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">9</span><span>]</span></span>\n          </div>\n          <div class=\"translation-block__english\">\n            <div class=\"english-line\"><strong>Line 4</strong> — <strong>Textual</strong>: Terminal UI framework for the interactive interface.</div>\n            <div class=\"english-line\"><strong>Line 5</strong> — <strong>LangChain Anthropic</strong>: Integrates Claude models with LangChain.</div>\n            <div class=\"english-line\"><strong>Line 6</strong> — <strong>LangGraph</strong>: Builds the agent graph with tools and memory.</div>\n            <div class=\"english-line\"><strong>Line 7</strong> — <strong>Anthropic</strong>: Low-level Claude API client.</div>\n            <div class=\"english-line\"><strong>Line 8</strong> — <strong>python-dotenv</strong>: Loads <code>.env</code> files for API keys.</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 4: Build Entry Point -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Build the entry point</h2>\n      <p class=\"text-lead mb-6\">The <code>main.py</code> is the first code that runs. It decides whether to launch the interactive app or handle a <span class=\"term\" data-tip=\"A subcommand is a second-level command that does something specific, like 'deepagents list' or 'deepagents reset'.\">subcommand</span>.</p>\n\n      <div class=\"translation-block\">\n        <div class=\"translation-block__header\">deepagents_cli/main.py — entry point</div>\n        <div class=\"translation-block__grid\">\n          <div class=\"translation-block__code\">\n<div class=\"code-pre\" style=\"white-space: pre-wrap; word-break: break-word;\"><span class=\"code-line\"><span class=\"code-line__num\">1</span><span>def cli_main() -> int:</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">2</span><span>    args = parse_args()</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">3</span><span>    if args.command == \"run\":</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">4</span><span>        run_app(args)  # TUI</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">5</span><span>    elif args.command == \"list\":</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">6</span><span>        list_agents(args)</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">7</span><span>    elif args.command == \"reset\":</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">8</span><span>        reset_agent(args)</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">9</span><span>    return 0</span></span>\n          </div>\n          <div class=\"translation-block__english\">\n            <div class=\"english-line\"><strong>Line 1</strong> — <code>cli_main()</code> is the main entry point. Returns an exit code.</div>\n            <div class=\"english-line\"><strong>Line 2</strong> — <code>parse_args()</code> reads CLI flags like <code>--agent</code>, <code>-r</code>.</div>\n            <div class=\"english-line\"><strong>Line 3-4</strong> — <code>deepagents</code> (no subcommand) launches the interactive app.</div>\n            <div class=\"english-line\"><strong>Line 5-6</strong> — <code>deepagents list</code> prints available agents.</div>\n            <div class=\"english-line\"><strong>Line 7-8</strong> — <code>deepagents reset</code> resets an agent's state.</div>\n            <div class=\"english-line\"><strong>Line 9</strong> — Return 0 means success; non-zero means error.</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"group-chat\">\n        <div class=\"group-chat__header\">\n          <span>🔄</span>\n          <span>Actor communication — \"user runs deepagents list\"</span>\n        </div>\n        <div class=\"group-chat__body\">\n          <div class=\"chat-bubble chat-bubble--left\">\n            <div class=\"chat-bubble__sender\">Terminal</div>\n            Runs <code>deepagents list</code>\n          </div>\n          <div class=\"chat-bubble chat-bubble--left\">\n            <div class=\"chat-bubble__sender\">main.py</div>\n            <code>parse_args()</code> sees <code>command=\"list\"</code>\n          </div>\n          <div class=\"chat-bubble chat-bubble--left\">\n            <div class=\"chat-bubble__sender\">agent.py</div>\n            <code>list_agents()</code> reads <code>~/.deepagents/</code>\n          </div>\n          <div class=\"chat-bubble chat-bubble--center\">No AI involved — pure file I/O.</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 5: Quiz -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Check your understanding</h2>\n\n      <div class=\"quiz\" id=\"quiz-module-1\">\n        <div class=\"quiz__question\">You want to add a <code>--debug</code> flag. Which file do you modify?</div>\n        <div class=\"quiz__options\">\n          <button class=\"quiz__option\" data-answer=\"a\">agent.py — that's where the agent logic lives</button>\n          <button class=\"quiz__option\" data-answer=\"b\">config.py — that's where settings are stored</button>\n          <button class=\"quiz__option\" data-answer=\"c\" data-correct=\"true\">main.py — that's where arguments are parsed</button>\n          <button class=\"quiz__option\" data-answer=\"d\">app.py — that's where the UI is rendered</button>\n        </div>\n        <div class=\"quiz__feedback quiz__feedback--correct\" data-for=\"c\">Right! <code>main.py</code> contains <code>parse_args()</code> which defines all CLI flags. Adding a new flag means modifying that function.</div>\n        <div class=\"quiz__feedback quiz__feedback--incorrect\" data-for=\"a\">Not quite — agent.py builds the agent but doesn't handle CLI argument parsing. That's in main.py.</div>\n        <div class=\"quiz__feedback quiz__feedback--incorrect\" data-for=\"b\">config.py handles runtime settings, not CLI argument parsing. Arguments are parsed in main.py's <code>parse_args()</code>.</div>\n        <div class=\"quiz__feedback quiz__feedback--incorrect\" data-for=\"d\">app.py handles the UI, not argument parsing. CLI flags go in main.py's <code>parse_args()</code>.</div>\n      </div>\n    </div>\n\n  </div>\n</section>\n\n\n<!-- MODULE 2: Your First Chat Loop -->\n<section class=\"module module--warm\" id=\"module-2\">\n  <div class=\"module__inner\">\n\n    <div class=\"module__header animate-in\">\n      <div class=\"module__number\">Module 2</div>\n      <h1 class=\"module__title\">Your First Chat Loop</h1>\n      <p class=\"module__subtitle\">Connect to a chat model and stream responses in the terminal.</p>\n    </div>\n\n    <!-- Screen 1: What is Streaming? -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">What is streaming?</h2>\n      <p class=\"text-lead mb-6\"><span class=\"term\" data-tip=\"Streaming delivers the AI response token-by-token as they're generated, instead of waiting for the complete response.\">Streaming</span> shows tokens as they arrive, character by character, like someone is typing live.</p>\n\n      <div class=\"data-flow\">\n        <div class=\"data-flow__track\" style=\"justify-content: center; gap: 16px;\">\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-2);\">👤</div>\n            <div class=\"flow-actor__name\">You</div>\n          </div>\n          <div class=\"flow-arrow\" style=\"position:relative;flex:none;width:40px;\"></div>\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-3);\">🔗</div>\n            <div class=\"flow-actor__name\">API</div>\n          </div>\n          <div class=\"flow-arrow\" style=\"position:relative;flex:none;width:40px;\"></div>\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-1);\">🤖</div>\n            <div class=\"flow-actor__name\">Tokens</div>\n          </div>\n          <div class=\"flow-arrow\" style=\"position:relative;flex:none;width:40px;\"></div>\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-5);\">📺</div>\n            <div class=\"flow-actor__name\">You</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"streaming-demo\">\n        <div style=\"margin-bottom: 8px; color: var(--color-text-muted);\">Streaming response:</div>\n        <span class=\"streaming-token\" style=\"animation-delay: 0ms;\">H</span><span class=\"streaming-token\" style=\"animation-delay: 150ms;\">e</span><span class=\"streaming-token\" style=\"animation-delay: 300ms;\">l</span><span class=\"streaming-token\" style=\"animation-delay: 450ms;\">l</span><span class=\"streaming-token\" style=\"animation-delay: 600ms;\">o</span><span class=\"streaming-token\" style=\"animation-delay: 750ms;\">,</span><span class=\"streaming-token\" style=\"animation-delay: 900ms;\"> </span><span class=\"streaming-token\" style=\"animation-delay: 1050ms;\">w</span><span class=\"streaming-token\" style=\"animation-delay: 1200ms;\">o</span><span class=\"streaming-token\" style=\"animation-delay: 1350ms;\">r</span><span class=\"streaming-token\" style=\"animation-delay: 1500ms;\">l</span><span class=\"streaming-token\" style=\"animation-delay: 1650ms;\">d</span><span class=\"streaming-token\" style=\"animation-delay: 1800ms;\">!</span>\n      </div>\n\n      <div class=\"callout callout--accent\">\n        <span class=\"callout__icon\">⚡</span>\n        <div class=\"callout__content\">\n          <div class=\"callout__title\">Why streaming matters</div>\n          Users see responses in real-time instead of waiting seconds for the full response. It feels like chatting with a real person.\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 2: Build the REPL Skeleton -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Build the REPL skeleton</h2>\n      <p class=\"text-lead mb-6\">A <span class=\"term\" data-tip=\"REPL = Read-Eval-Print Loop. It reads input, evaluates it, prints the result, then loops back to wait for more input.\">REPL</span> (Read-Eval-Print Loop) is the core pattern: read input, send to AI, print response, repeat.</p>\n\n      <div class=\"step-cards\">\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">1</div>\n          <div>\n            <div class=\"step-card__title\">Read input</div>\n            <div class=\"step-card__desc\">Capture user message from the terminal input.</div>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">2</div>\n          <div>\n            <div class=\"step-card__title\">Send to model</div>\n            <div class=\"step-card__desc\">Pass the message to the language model.</div>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">3</div>\n          <div>\n            <div class=\"step-card__title\">Stream response</div>\n            <div class=\"step-card__desc\">Print tokens as they arrive from the API.</div>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">4</div>\n          <div>\n            <div class=\"step-card__title\">Loop</div>\n            <div class=\"step-card__desc\">Wait for the next user message.</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"group-chat\">\n        <div class=\"group-chat__header\">\n          <span>💬</span>\n          <span>REPL loop in action</span>\n        </div>\n        <div class=\"group-chat__body\">\n          <div class=\"chat-bubble chat-bubble--left\">\n            <div class=\"chat-bubble__sender\">You</div>\n            \"fix the login bug\"\n          </div>\n          <div class=\"chat-bubble chat-bubble--right\">\n            <div class=\"chat-bubble__sender\">AI</div>\n            <span class=\"typing-indicator\"><span></span><span></span><span></span></span>\n          </div>\n          <div class=\"chat-bubble chat-bubble--right\">\n            <div class=\"chat-bubble__sender\">AI</div>\n            Let me look at the auth code...\n          </div>\n          <div class=\"chat-bubble chat-bubble--left\">\n            <div class=\"chat-bubble__sender\">You</div>\n            \"show me the files\"\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 3: Connect the LLM -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Connect the LLM</h2>\n      <p class=\"text-lead mb-6\">Use <span class=\"term\" data-tip=\"LangChain is a framework for building applications with language models. It provides abstractions for prompts, models, and tools.\">LangChain</span> to connect to Anthropic's Claude model.</p>\n\n      <div class=\"translation-block\">\n        <div class=\"translation-block__header\">Connecting to Claude</div>\n        <div class=\"translation-block__grid\">\n          <div class=\"translation-block__code\">\n<div class=\"code-pre\" style=\"white-space: pre-wrap; word-break: break-word;\"><span class=\"code-line\"><span class=\"code-line__num\">1</span><span>from langchain_anthropic import ChatAnthropic</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">2</span><span></span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">3</span><span>model = ChatAnthropic(</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">4</span><span>    model=\"claude-sonnet-4-6\",</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">5</span><span>    anthropic_api_key=os.environ[\"ANTHROPIC_API_KEY\"],</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">6</span><span>)</span></span>\n          </div>\n          <div class=\"translation-block__english\">\n            <div class=\"english-line\"><strong>Line 1</strong> — Import LangChain's Anthropic chat model wrapper.</div>\n            <div class=\"english-line\"><strong>Line 3-6</strong> — Create a chat model instance with your API key from environment.</div>\n            <div class=\"english-line\">The model name <code>claude-sonnet-4-6</code> can be changed to any Anthropic model.</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"icon-row\">\n        <div class=\"icon-item\">\n          <span class=\"icon-item__emoji\">🔑</span>\n          <span class=\"icon-item__label\">ANTHROPIC_API_KEY</span>\n        </div>\n        <div class=\"icon-item\">\n          <span class=\"icon-item__emoji\">→</span>\n          <span class=\"icon-item__label\">LangChain</span>\n        </div>\n        <div class=\"icon-item\">\n          <span class=\"icon-item__emoji\">→</span>\n          <span class=\"icon-item__label\">Claude API</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 4: Add Streaming -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Add streaming</h2>\n      <p class=\"text-lead mb-6\">Use <code>.stream()</code> instead of <code>.invoke()</code> to get tokens as they arrive.</p>\n\n      <div class=\"translation-block\">\n        <div class=\"translation-block__header\">stream() vs invoke()</div>\n        <div class=\"translation-block__grid\">\n          <div class=\"translation-block__code\">\n<div class=\"code-pre\" style=\"white-space: pre-wrap; word-break: break-word;\"><span class=\"code-line\"><span class=\"code-line__num\">1</span><span># Non-streaming: waits for complete response</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">2</span><span>response = model.invoke(messages)</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">3</span><span></span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">4</span><span># Streaming: yields tokens as they arrive</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">5</span><span>for token in model.stream(messages):</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">6</span><span>    print(token.content, end=\"\", flush=True)</span></span>\n          </div>\n          <div class=\"translation-block__english\">\n            <div class=\"english-line\"><strong>Line 2</strong> — <code>invoke()</code> blocks until the complete response is ready.</div>\n            <div class=\"english-line\"><strong>Line 5-6</strong> — <code>stream()</code> yields each token as it arrives. The <code>flush=True</code> forces immediate display.</div>\n            <div class=\"english-line\">Streaming gives a 100-500ms perceived speedup for long responses.</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"data-flow\">\n        <div class=\"data-flow__track\" style=\"justify-content: center; gap: 16px;\">\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-2);\">👤</div>\n            <div class=\"flow-actor__name\">User</div>\n          </div>\n          <div class=\"flow-arrow\" style=\"position:relative;flex:none;width:40px;\"></div>\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-3);\">🔗</div>\n            <div class=\"flow-actor__name\">Claude API</div>\n          </div>\n          <div class=\"flow-arrow\" style=\"position:relative;flex:none;width:40px;\"></div>\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-1);\">📺</div>\n            <div class=\"flow-actor__name\">Token 1, Token 2...</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 5: Quiz -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Check your understanding</h2>\n\n      <div class=\"quiz\" id=\"quiz-module-2\">\n        <div class=\"quiz__question\">The AI response is slow and you can't see any output until it's complete. What did you probably use instead of <code>stream()</code>?</div>\n        <div class=\"quiz__options\">\n          <button class=\"quiz__option\" data-answer=\"a\" data-correct=\"true\">invoke() — it waits for the complete response</button>\n          <button class=\"quiz__option\" data-answer=\"b\">batch() — it's for processing multiple requests</button>\n          <button class=\"quiz__option\" data-answer=\"c\">ainvoke() — it's the async version of invoke</button>\n          <button class=\"quiz__option\" data-answer=\"d\">agenerate() — it's for async generation</button>\n        </div>\n        <div class=\"quiz__feedback quiz__feedback--correct\" data-for=\"a\">Exactly! <code>invoke()</code> blocks until the complete response arrives. <code>stream()</code> yields tokens one by one as they arrive from the API.</div>\n        <div class=\"quiz__feedback quiz__feedback--incorrect\" data-for=\"b\"><code>batch()</code> processes multiple requests at once, not a single streaming response.</div>\n        <div class=\"quiz__feedback quiz__feedback--incorrect\" data-for=\"c\"><code>ainvoke()</code> is async but still waits for the complete response — no streaming.</div>\n        <div class=\"quiz__feedback quiz__feedback--incorrect\" data-for=\"d\"><code>agenerate()</code> is for async generation but doesn't stream tokens.</div>\n      </div>\n    </div>\n\n  </div>\n</section>\n\n\n<!-- MODULE 3: Giving the AI Tools -->\n<section class=\"module\" id=\"module-3\">\n  <div class=\"module__inner\">\n\n    <div class=\"module__header animate-in\">\n      <div class=\"module__number\">Module 3</div>\n      <h1 class=\"module__title\">Giving the AI Tools</h1>\n      <p class=\"module__subtitle\">Give the agent actual capabilities — read files, write files, run shell commands.</p>\n    </div>\n\n    <!-- Screen 1: What is a Tool? -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">What is a tool?</h2>\n      <p class=\"text-lead mb-6\">A <span class=\"term\" data-tip=\"A function the AI can invoke during conversation — like reading a file, running a command, or searching the web. The AI decides which tools to call based on your request.\">tool</span> is a function the AI can call. The AI sees your request, decides it needs to read a file, and calls the tool directly.</p>\n\n      <div class=\"group-chat\">\n        <div class=\"group-chat__header\">\n          <span>🔧</span>\n          <span>Tool call flow — AI needs to read auth.py</span>\n        </div>\n        <div class=\"group-chat__body\">\n          <div class=\"chat-bubble chat-bubble--left\">\n            <div class=\"chat-bubble__sender\">You</div>\n            \"check the auth.py file\"\n          </div>\n          <div class=\"chat-bubble chat-bubble--right\">\n            <div class=\"chat-bubble__sender\">AI</div>\n            <span class=\"typing-indicator\"><span></span><span></span><span></span></span>\n          </div>\n          <div class=\"chat-bubble chat-bubble--center\">Tool call: read_file(file_path=\"auth.py\")</div>\n          <div class=\"chat-bubble chat-bubble--right\">\n            <div class=\"chat-bubble__sender\">Tool: read_file</div>\n            [47 lines of auth.py content]\n          </div>\n          <div class=\"chat-bubble chat-bubble--left\">\n            <div class=\"chat-bubble__sender\">AI</div>\n            Found the issue on line 34...\n          </div>\n        </div>\n      </div>\n\n      <div class=\"callout callout--info\">\n        <span class=\"callout__icon\">💡</span>\n        <div class=\"callout__content\">\n          <div class=\"callout__title\">Tool = function the AI can call</div>\n          Tools extend what the AI can do. Without tools, the AI can only text-chat. With tools, it can read files, run commands, search the web, and more.\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 2: Build ReadFileTool -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Build ReadFileTool</h2>\n      <p class=\"text-lead mb-6\">Create a tool that lets the AI read files from the filesystem.</p>\n\n      <div class=\"translation-block\">\n        <div class=\"translation-block__header\">ReadFileTool implementation</div>\n        <div class=\"translation-block__grid\">\n          <div class=\"translation-block__code\">\n<div class=\"code-pre\" style=\"white-space: pre-wrap; word-break: break-word;\"><span class=\"code-line\"><span class=\"code-line__num\">1</span><span>from langchain.tools import tool</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">2</span><span>from pathlib import Path</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">3</span><span></span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">4</span><span>@tool</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">5</span><span>def read_file(file_path: str) -> str:</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">6</span><span>    \"\"\"Read content from a file.\"\"\"</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">7</span><span>    path = Path(file_path)</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">8</span><span>    if not path.exists():</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">9</span><span>        return f\"Error: {file_path} not found\"</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">10</span><span>    return path.read_text()</span></span>\n          </div>\n          <div class=\"translation-block__english\">\n            <div class=\"english-line\"><strong>Line 1</strong> — Import the <code>@tool</code> decorator from LangChain.</div>\n            <div class=\"english-line\"><strong>Line 4</strong> — <code>@tool</code> decorator marks this as an AI-callable function.</div>\n            <div class=\"english-line\"><strong>Line 5</strong> — The function name becomes the tool name: <code>read_file</code>.</div>\n            <div class=\"english-line\"><strong>Line 6</strong> — The docstring becomes the tool description the AI reads.</div>\n            <div class=\"english-line\"><strong>Line 7-10</strong> — Implementation: check existence, read and return content.</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 3: Build WriteFileTool -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Build WriteFileTool</h2>\n      <p class=\"text-lead mb-6\">Create a tool that lets the AI write or overwrite files.</p>\n\n      <div class=\"translation-block\">\n        <div class=\"translation-block__header\">WriteFileTool implementation</div>\n        <div class=\"translation-block__grid\">\n          <div class=\"translation-block__code\">\n<div class=\"code-pre\" style=\"white-space: pre-wrap; word-break: break-word;\"><span class=\"code-line\"><span class=\"code-line__num\">1</span><span>@tool</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">2</span><span>def write_file(file_path: str, content: str) -> str:</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">3</span><span>    \"\"\"Write content to a file.\"\"\"</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">4</span><span>    path = Path(file_path)</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">5</span><span>    path.parent.mkdir(parents=True, exist_ok=True)</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">6</span><span>    path.write_text(content)</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">7</span><span>    return f\"Wrote {len(content)} chars to {file_path}\"</span></span>\n          </div>\n          <div class=\"translation-block__english\">\n            <div class=\"english-line\"><strong>Line 2</strong> — Two parameters: <code>file_path</code> and <code>content</code>. The AI must provide both.</div>\n            <div class=\"english-line\"><strong>Line 5</strong> — <code>mkdir(parents=True, exist_ok=True)</code> creates parent directories if needed.</div>\n            <div class=\"english-line\"><strong>Line 6</strong> — <code>write_text()</code> overwrites the file with new content.</div>\n            <div class=\"english-line\"><strong>Line 7</strong> — Return a confirmation message the AI can relay to you.</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"callout callout--accent\">\n        <span class=\"callout__icon\">⚠️</span>\n        <div class=\"callout__content\">\n          <div class=\"callout__title\">Security note</div>\n          File write tools are powerful. In module 4, we'll add a Human-in-the-Loop gate that asks for approval before writing.\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 4: Build ExecuteTool -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Build ExecuteTool</h2>\n      <p class=\"text-lead mb-6\">Create a tool that runs <span class=\"term\" data-tip=\"Shell commands are executed in a terminal, like 'ls', 'grep', or 'git commit'. The execute tool gives the AI shell access.\">shell commands</span>.</p>\n\n      <div class=\"translation-block\">\n        <div class=\"translation-block__header\">ExecuteTool implementation</div>\n        <div class=\"translation-block__grid\">\n          <div class=\"translation-block__code\">\n<div class=\"code-pre\" style=\"white-space: pre-wrap; word-break: break-word;\"><span class=\"code-line\"><span class=\"code-line__num\">1</span><span>import subprocess</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">2</span><span></span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">3</span><span>@tool</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">4</span><span>def execute(command: str) -> str:</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">5</span><span>    \"\"\"Execute a shell command.\"\"\"</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">6</span><span>    result = subprocess.run(</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">7</span><span>        command, shell=True, capture_output=True, text=True</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">8</span><span>    )</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">9</span><span>    return result.stdout + result.stderr</span></span>\n          </div>\n          <div class=\"translation-block__english\">\n            <div class=\"english-line\"><strong>Line 1</strong> — <code>subprocess</code> runs external programs safely.</div>\n            <div class=\"english-line\"><strong>Line 6-8</strong> — <code>subprocess.run()</code> executes the command. <code>shell=True</code> enables shell features.</div>\n            <div class=\"english-line\"><strong>Line 9</strong> — Return both stdout (output) and stderr (errors).</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"pattern-cards\">\n        <div class=\"pattern-card\">\n          <div class=\"pattern-card__icon\">📂</div>\n          <div class=\"pattern-card__title\">ls, cat, grep</div>\n          <div class=\"pattern-card__desc\">Directory listing and file content inspection.</div>\n        </div>\n        <div class=\"pattern-card\">\n          <div class=\"pattern-card__icon\">🔍</div>\n          <div class=\"pattern-card__title\">find, rg</div>\n          <div class=\"pattern-card__desc\">Searching for files and content.</div>\n        </div>\n        <div class=\"pattern-card\">\n          <div class=\"pattern-card__icon\">⚙️</div>\n          <div class=\"pattern-card__title\">git, npm</div>\n          <div class=\"pattern-card__desc\">Version control and package management.</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 5: Wire Tools Into Agent -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Wire tools into the agent</h2>\n      <p class=\"text-lead mb-6\">Pass the tools list to LangGraph's <span class=\"term\" data-tip=\"create_react_agent creates a ReAct (Reasoning + Acting) agent that can use tools. It's the standard agent type in LangGraph.\">create_react_agent</span>.</p>\n\n      <div class=\"translation-block\">\n        <div class=\"translation-block__header\">create_react_agent with tools</div>\n        <div class=\"translation-block__grid\">\n          <div class=\"translation-block__code\">\n<div class=\"code-pre\" style=\"white-space: pre-wrap; word-break: break-word;\"><span class=\"code-line\"><span class=\"code-line__num\">1</span><span>from langgraph.prebuilt import create_react_agent</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">2</span><span></span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">3</span><span>tools = [read_file, write_file, execute]</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">4</span><span></span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">5</span><span>agent = create_react_agent(</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">6</span><span>    model=model,</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">7</span><span>    tools=tools,</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">8</span><span>)</span></span>\n          </div>\n          <div class=\"translation-block__english\">\n            <div class=\"english-line\"><strong>Line 1</strong> — Import the ReAct agent builder from LangGraph.</div>\n            <div class=\"english-line\"><strong>Line 3</strong> — Collect all tools into a list.</div>\n            <div class=\"english-line\"><strong>Line 5-8</strong> — Create the agent with the model and tools. The agent can now call any of these tools.</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"data-flow\">\n        <div class=\"data-flow__track\" style=\"justify-content: center; gap: 16px;\">\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-2);\">👤</div>\n            <div class=\"flow-actor__name\">User</div>\n          </div>\n          <div class=\"flow-arrow\" style=\"position:relative;flex:none;width:40px;\"></div>\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-1);\">🤖</div>\n            <div class=\"flow-actor__name\">Agent</div>\n          </div>\n          <div class=\"flow-arrow\" style=\"position:relative;flex:none;width:40px;\"></div>\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-3);\">🔧</div>\n            <div class=\"flow-actor__name\">Tools</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 6: Quiz -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Check your understanding</h2>\n\n      <div class=\"quiz\" id=\"quiz-module-3\">\n        <div class=\"quiz__question\">You want to add a web search tool. What do you add to the tools list?</div>\n        <div class=\"quiz__options\">\n          <button class=\"quiz__option\" data-answer=\"a\">A new API key in config.py</button>\n          <button class=\"quiz__option\" data-answer=\"b\" data-correct=\"true\">A function decorated with @tool, like web_search</button>\n          <button class=\"quiz__option\" data-answer=\"c\">A new command-line flag</button>\n          <button class=\"quiz__option\" data-answer=\"d\">A new submodule in app.py</button>\n        </div>\n        <div class=\"quiz__feedback quiz__feedback--correct\" data-for=\"b\">Right! Tools are Python functions decorated with <code>@tool</code>. Add the function to the tools list passed to <code>create_react_agent()</code>.</div>\n        <div class=\"quiz__feedback quiz__feedback--incorrect\" data-for=\"a\">An API key is for authentication, but you still need a tool function to actually perform the search.</div>\n        <div class=\"quiz__feedback quiz__feedback--incorrect\" data-for=\"c\">Command-line flags are for CLI arguments, not agent capabilities. Tools are functions.</div>\n        <div class=\"quiz__feedback quiz__feedback--incorrect\" data-for=\"d\">Submodules organize code, but tools are functions that the agent can call.</div>\n      </div>\n    </div>\n\n  </div>\n</section>\n\n\n<!-- MODULE 4: The Human-in-the-Loop Gate -->\n<section class=\"module module--warm\" id=\"module-4\">\n  <div class=\"module__inner\">\n\n    <div class=\"module__header animate-in\">\n      <div class=\"module__number\">Module 4</div>\n      <h1 class=\"module__title\">The Human-in-the-Loop Gate</h1>\n      <p class=\"module__subtitle\">Pause before dangerous operations, require approval.</p>\n    </div>\n\n    <!-- Screen 1: Why HITL? -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Why HITL?</h2>\n      <p class=\"text-lead mb-6\">Imagine a bouncer at a club. The AI wants to do something risky — <code>rm -rf /tmp</code>, write to <code>auth.py</code>, search the web. It stops and asks: \"Should I let this through?\"</p>\n\n      <div class=\"callout callout--info\">\n        <span class=\"callout__icon\">🚪</span>\n        <div class=\"callout__content\">\n          <div class=\"callout__title\">The nightclub metaphor</div>\n          Without HITL: AI can run any tool, anytime — like a club with no bouncer. With HITL: AI pauses at dangerous tools and asks permission — like a club with a strict bouncer checking IDs.\n        </div>\n      </div>\n\n      <div class=\"pattern-cards\">\n        <div class=\"pattern-card\">\n          <div class=\"pattern-card__icon\">💻</div>\n          <div class=\"pattern-card__title\">execute</div>\n          <div class=\"pattern-card__desc\">Shell commands — most dangerous. Always gated.</div>\n        </div>\n        <div class=\"pattern-card\">\n          <div class=\"pattern-card__icon\">📝</div>\n          <div class=\"pattern-card__title\">write_file</div>\n          <div class=\"pattern-card__desc\">Creates or overwrites files.</div>\n        </div>\n        <div class=\"pattern-card\">\n          <div class=\"pattern-card__icon\">🔍</div>\n          <div class=\"pattern-card__title\">web_search</div>\n          <div class=\"pattern-card__desc\">Uses API credits and shares your query.</div>\n        </div>\n        <div class=\"pattern-card\">\n          <div class=\"pattern-card__icon\">🌐</div>\n          <div class=\"pattern-card__title\">fetch_url</div>\n          <div class=\"pattern-card__desc\">Reads content from any URL.</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 2: Design the Approval Prompt -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Design the approval prompt</h2>\n      <p class=\"text-lead mb-6\">When a gated tool is called, the CLI shows an approval prompt with the tool name, arguments, and risk description.</p>\n\n      <div class=\"group-chat\">\n        <div class=\"group-chat__header\">\n          <span>🛑</span>\n          <span>HITL interrupt — AI wants to run rm -rf</span>\n        </div>\n        <div class=\"group-chat__body\">\n          <div class=\"chat-bubble chat-bubble--center\">\n            ⚠️ Tool approval required\n          </div>\n          <div class=\"chat-bubble chat-bubble--left\">\n            <div class=\"chat-bubble__sender\">Tool</div>\n            execute(command=\"rm -rf /tmp/test\")\n          </div>\n          <div class=\"chat-bubble chat-bubble--right\">\n            <div class=\"chat-bubble__sender\">🤖 Agent</div>\n            <span class=\"typing-indicator\"><span></span><span></span><span></span></span>\n          </div>\n          <div class=\"chat-bubble chat-bubble--center\">\n            [Approve] [Reject] [Approve all future]\n          </div>\n        </div>\n      </div>\n\n      <div class=\"translation-block\">\n        <div class=\"translation-block__header\">interrupt_on config (from agent.py)</div>\n        <div class=\"translation-block__grid\">\n          <div class=\"translation-block__code\">\n<div class=\"code-pre\" style=\"white-space: pre-wrap; word-break: break-word;\"><span class=\"code-line\"><span class=\"code-line__num\">1</span><span>execute_interrupt = {</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">2</span><span>    \"allowed_decisions\": [\"approve\", \"reject\"],</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">3</span><span>    \"description\": _format_execute_description,</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">4</span><span>}</span></span>\n          </div>\n          <div class=\"translation-block__english\">\n            <div class=\"english-line\"><strong>Line 2</strong> — The only decisions allowed: approve or reject. No auto-denial.</div>\n            <div class=\"english-line\"><strong>Line 3</strong> — A function that formats the tool call description for the approval prompt.</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 3: Implement Interrupt Handler -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Implement the interrupt handler</h2>\n      <p class=\"text-lead mb-6\">When a gated tool is called, LangGraph pauses and waits for a human decision.</p>\n\n      <div class=\"step-cards\">\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">1</div>\n          <div>\n            <div class=\"step-card__title\">Detect tool call</div>\n            <div class=\"step-card__desc\">Agent invokes a gated tool like execute or write_file.</div>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">2</div>\n          <div>\n            <div class=\"step-card__title\">Format description</div>\n            <div class=\"step-card__desc\">Generate a human-readable description of what the tool will do.</div>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">3</div>\n          <div>\n            <div class=\"step-card__title\">Show approval menu</div>\n            <div class=\"step-card__desc\">Display the tool call and [Approve] [Reject] buttons.</div>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">4</div>\n          <div>\n            <div class=\"step-card__title\">Wait for decision</div>\n            <div class=\"step-card__desc\">Graph is paused. User clicks Approve or Reject.</div>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">5</div>\n          <div>\n            <div class=\"step-card__title\">Resume or reject</div>\n            <div class=\"step-card__desc\">If approved, tool executes. If rejected, error is returned to agent.</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 4: Add --auto-approve Flag -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Add --auto-approve flag</h2>\n      <p class=\"text-lead mb-6\">For <span class=\"term\" data-tip=\"CI = Continuous Integration. Automated pipelines that run tests on every commit. In CI, there's no human to approve tool calls.\">CI</span> and scripting, you can bypass all HITL gates with <code>--auto-approve</code>.</p>\n\n      <div class=\"translation-block\">\n        <div class=\"translation-block__header\">auto_approve logic</div>\n        <div class=\"translation-block__grid\">\n          <div class=\"translation-block__code\">\n<div class=\"code-pre\" style=\"white-space: pre-wrap; word-break: break-word;\"><span class=\"code-line\"><span class=\"code-line__num\">1</span><span>if auto_approve:</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">2</span><span>    # No interrupts - all tools run automatically</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">3</span><span>    interrupt_on = {}</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">4</span><span>else:</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">5</span><span>    # Full HITL for destructive operations</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">6</span><span>    interrupt_on = _add_interrupt_on()</span></span>\n          </div>\n          <div class=\"translation-block__english\">\n            <div class=\"english-line\"><strong>Line 1-3</strong> — When <code>auto_approve=True</code>, <code>interrupt_on={}</code> means no tools are gated. All tools run immediately.</div>\n            <div class=\"english-line\"><strong>Line 4-6</strong> — When <code>auto_approve=False</code> (default), <code>_add_interrupt_on()</code> returns the full map of gated tools.</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"callout callout--accent\">\n        <span class=\"callout__icon\">⚡</span>\n        <div class=\"callout__content\">\n          <div class=\"callout__title\">When to use --auto-approve</div>\n          Use it in CI scripts, automated pipelines, or when you trust the AI completely. Never use it interactively with unfamiliar prompts.\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 5: Quiz -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Check your understanding</h2>\n\n      <div class=\"quiz\" id=\"quiz-module-4\">\n        <div class=\"quiz__question\">A user reports: \"I ran with --auto-approve and the AI deleted my entire project!\" What went wrong?</div>\n        <div class=\"quiz__options\">\n          <button class=\"quiz__option\" data-answer=\"a\">The auto-approve flag wasn't implemented correctly</button>\n          <button class=\"quiz__option\" data-answer=\"b\">--auto-approve bypasses ALL tool approvals, including dangerous ones like rm -rf</button>\n          <button class=\"quiz__option\" data-answer=\"c\">The AI should have refused to run dangerous commands anyway</button>\n          <button class=\"quiz__option\" data-answer=\"d\">HITL was working but the user clicked approve</button>\n        </div>\n        <div class=\"quiz__feedback quiz__feedback--correct\" data-for=\"b\">Exactly! <code>--auto-approve</code> bypasses every HITL gate. With it enabled, the AI can run <code>rm -rf</code>, write files, anything — without asking. That's the intended behavior for CI, but dangerous interactively.</div>\n        <div class=\"quiz__feedback quiz__feedback--incorrect\" data-for=\"a\">The flag works exactly as designed — it bypasses all approvals.</div>\n        <div class=\"quiz__feedback quiz__feedback--incorrect\" data-for=\"c\">Without HITL, the AI will run any tool the task requires, including dangerous ones.</div>\n        <div class=\"quiz__feedback quiz__feedback--incorrect\" data-for=\"d\">With <code>--auto-approve</code>, no approval prompt is shown at all.</div>\n      </div>\n    </div>\n\n  </div>\n</section>\n\n\n<!-- MODULE 5: Conversations That Remember -->\n<section class=\"module\" id=\"module-5\">\n  <div class=\"module__inner\">\n\n    <div class=\"module__header animate-in\">\n      <div class=\"module__number\">Module 5</div>\n      <h1 class=\"module__title\">Conversations That Remember</h1>\n      <p class=\"module__subtitle\">Add session management and message history.</p>\n    </div>\n\n    <!-- Screen 1: What is State? -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">What is state?</h2>\n      <p class=\"text-lead mb-6\"><span class=\"term\" data-tip=\"Stateless means each request is independent — no memory of previous requests. Stateful means the system remembers past interactions.\">Stateless</span> vs <span class=\"term\" data-tip=\"Stateful means the system maintains memory of past interactions across requests.\">stateful</span>: a walkie-talkie is stateless (each message is independent), a phone call is stateful (you remember what was said before).</p>\n\n      <div class=\"group-chat\">\n        <div class=\"group-chat__header\">\n          <span>📞</span>\n          <span>Stateless vs Stateful</span>\n        </div>\n        <div class=\"group-chat__body\">\n          <div class=\"chat-bubble chat-bubble--left\">\n            <div class=\"chat-bubble__sender\">You (stateless)</div>\n            \"fix the bug\"\n          </div>\n          <div class=\"chat-bubble chat-bubble--left\">\n            <div class=\"chat-bubble__sender\">AI</div>\n            \"What bug? I don't know which bug you mean.\"\n          </div>\n          <div class=\"chat-bubble chat-bubble--left\">\n            <div class=\"chat-bubble__sender\">You (stateful)</div>\n            \"fix the bug\"\n          </div>\n          <div class=\"chat-bubble chat-bubble--left\">\n            <div class=\"chat-bubble__sender\">AI</div>\n            \"The login bug on line 34? I already found it...\"\n          </div>\n        </div>\n      </div>\n\n      <div class=\"callout callout--info\">\n        <span class=\"callout__icon\">🧠</span>\n        <div class=\"callout__content\">\n          <div class=\"callout__title\">Why state matters</div>\n          Without state, every message is treated as independent. The AI can't remember you just described a bug. With state, the AI reads the full conversation history.\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 2: Generate Thread IDs -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Generate thread IDs</h2>\n      <p class=\"text-lead mb-6\">A <span class=\"term\" data-tip=\"A thread ID is a unique identifier for a conversation session. It lets the system store and retrieve message history for a specific conversation.\">thread ID</span> uniquely identifies each conversation session. Generate one with <code>uuid.uuid4()</code>.</p>\n\n      <div class=\"translation-block\">\n        <div class=\"translation-block__header\">generate_thread_id()</div>\n        <div class=\"translation-block__grid\">\n          <div class=\"translation-block__code\">\n<div class=\"code-pre\" style=\"white-space: pre-wrap; word-break: break-word;\"><span class=\"code-line\"><span class=\"code-line__num\">1</span><span>import uuid</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">2</span><span></span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">3</span><span>def generate_thread_id() -> str:</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">4</span><span>    return str(uuid.uuid4())</span></span>\n          </div>\n          <div class=\"translation-block__english\">\n            <div class=\"english-line\"><strong>Line 4</strong> — <code>uuid.uuid4()</code> generates a random UUID like <code>\"a1b2c3d4-...\"</code>. Convert to string for storage.</div>\n            <div class=\"english-line\">Each conversation session gets its own unique ID. This ID is used to store and retrieve message history.</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"data-flow\">\n        <div class=\"data-flow__track\" style=\"justify-content: center; gap: 16px;\">\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-2);\">👤</div>\n            <div class=\"flow-actor__name\">User starts session</div>\n          </div>\n          <div class=\"flow-arrow\" style=\"position:relative;flex:none;width:40px;\"></div>\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-3);\">🆔</div>\n            <div class=\"flow-actor__name\">Generate UUID</div>\n          </div>\n          <div class=\"flow-arrow\" style=\"position:relative;flex:none;width:40px;\"></div>\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-5);\">💾</div>\n            <div class=\"flow-actor__name\">Store in session</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 3: Store Message History -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Store message history</h2>\n      <p class=\"text-lead mb-6\">After each exchange, append to a list that stores the conversation.</p>\n\n      <div class=\"step-cards\">\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">1</div>\n          <div>\n            <div class=\"step-card__title\">Capture user message</div>\n            <div class=\"step-card__desc\">Store the human's message with role \"user\".</div>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">2</div>\n          <div>\n            <div class=\"step-card__title\">Capture AI response</div>\n            <div class=\"step-card__desc\">Store the AI's response with role \"assistant\".</div>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">3</div>\n          <div>\n            <div class=\"step-card__title\">Append to history</div>\n            <div class=\"step-card__desc\">Add both to the messages list.</div>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-card__num\">4</div>\n          <div>\n            <div class=\"step-card__title\">Store in checkpoint</div>\n            <div class=\"step-card__desc\">Save to disk or memory with thread_id as key.</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"translation-block\">\n        <div class=\"translation-block__header\">Message history pattern</div>\n        <div class=\"translation-block__grid\">\n          <div class=\"translation-block__code\">\n<div class=\"code-pre\" style=\"white-space: pre-wrap; word-break: break-word;\"><span class=\"code-line\"><span class=\"code-line__num\">1</span><span>messages = []</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">2</span><span></span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">3</span><span># After user sends message</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">4</span><span>messages.append(HumanMessage(content=\"fix the bug\"))</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">5</span><span></span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">6</span><span># After AI responds</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">7</span><span>messages.append(AIMessage(content=\"Which file?\"))</span></span>\n          </div>\n          <div class=\"translation-block__english\">\n            <div class=\"english-line\"><strong>Line 1</strong> — Start with an empty messages list.</div>\n            <div class=\"english-line\"><strong>Line 4</strong> — Append user's message as <code>HumanMessage</code>.</div>\n            <div class=\"english-line\"><strong>Line 7</strong> — Append AI's response as <code>AIMessage</code>.</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 4: Prepend History to Prompt -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Prepend history to each prompt</h2>\n      <p class=\"text-lead mb-6\">Before sending a new message, prepend the full history so the AI has context.</p>\n\n      <div class=\"translation-block\">\n        <div class=\"translation-block__header\">Assembly with history</div>\n        <div class=\"translation-block__grid\">\n          <div class=\"translation-block__code\">\n<div class=\"code-pre\" style=\"white-space: pre-wrap; word-break: break-word;\"><span class=\"code-line\"><span class=\"code-line__num\">1</span><span>def build_prompt(user_message: str, history: list) -> list:</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">2</span><span>    # Start with system prompt</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">3</span><span>    messages = [SystemMessage(content=SYSTEM_PROMPT)]</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">4</span><span>    # Add conversation history</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">5</span><span>    messages.extend(history)</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">6</span><span>    # Add current message</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">7</span><span>    messages.append(HumanMessage(content=user_message))</span></span>\n<span class=\"code-line\"><span class=\"code-line__num\">8</span><span>    return messages</span></span>\n          </div>\n          <div class=\"translation-block__english\">\n            <div class=\"english-line\"><strong>Line 3</strong> — System message sets the AI's role and instructions.</div>\n            <div class=\"english-line\"><strong>Line 5</strong> — <code>extend(history)</code> adds all previous messages.</div>\n            <div class=\"english-line\"><strong>Line 7</strong> — Append the new user message at the end.</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"data-flow\">\n        <div class=\"data-flow__track\" style=\"justify-content: center; gap: 16px;\">\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-2);\">📜</div>\n            <div class=\"flow-actor__name\">History</div>\n          </div>\n          <div class=\"flow-arrow\" style=\"position:relative;flex:none;width:40px;\"></div>\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-4);\">➕</div>\n            <div class=\"flow-actor__name\">+ Current msg</div>\n          </div>\n          <div class=\"flow-arrow\" style=\"position:relative;flex:none;width:40px;\"></div>\n          <div class=\"flow-actor\">\n            <div class=\"flow-actor__icon\" style=\"background: var(--color-actor-1);\">🤖</div>\n            <div class=\"flow-actor__name\">LLM</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Screen 5: Add /clear Command -->\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen__title\">Add /clear command</h2>\n      <p class=\"text-lead mb-6\">The <code>/clear</code> slash command resets the conversation history for the current thread.</p>\n\n      <div class=\"group-chat\">\n        <div class=\"group-chat__header\">\n          <span>🧹</span>\n          <span>/clear command flow</span>\n        </div>\n        <div class=\"group-chat__body\">\n          <div class=\"chat-bubble chat-bubble--left\">\n            <div class=\"chat-bubble__sender\">You</div>\n            /clear\n          </div>\n          <div class=\"chat-bubble chat-bubble--center\">\n            Slash command detected — bypass_tier=QUEUED\n          </div>\n          <div class=\"chat-bubble chat-bubble--right\">\n            <div class=\"chat-bubble__sender\">CLI</div>\n            Chat clea